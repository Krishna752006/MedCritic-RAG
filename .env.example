ENV=development
APP_NAME=MedCritic-RAG++ Backend Service
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:3000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/medcritic
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
LOG_LEVEL=INFO
MAX_UPLOAD_MB=25
